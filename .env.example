PORT=3000

# --- Firebase Admin SDK (backend) ---
# Obtén estos valores desde Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://tu-proyecto-default-rtdb.firebaseio.com

# --- Firebase JS SDK (frontend, valores públicos) ---
# Obtén estos valores desde Firebase Console > Project Settings > General > Your apps > Web app
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123
